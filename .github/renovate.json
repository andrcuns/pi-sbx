{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "enabledManagers": [
    "custom.regex",
    "npm",
    "mise",
    "dockerfile",
    "github-actions"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^\\.github/workflows/build\\.yml$"
      ],
      "matchStrings": [
        "MISE_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "jdx/mise",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/)pi$"
      ],
      "matchStrings": [
        "ghcr\\.io/andrcuns/pi-docker:(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "@mariozechner/pi-coding-agent",
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "groupName": "pi coding agent",
      "matchManagers": [
        "npm",
        "regex"
      ],
      "matchPackageNames": [
        "@mariozechner/pi-coding-agent"
      ]
    }
  ]
}
