{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "enabledManagers": [
    "custom.regex",
    "dockerfile",
    "github-actions"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^\\.github/workflows/build\\.yml$"
      ],
      "matchStrings": [
        "\"tag=(?<currentValue>[^\\s]+)\""
      ],
      "depNameTemplate": "jdx/mise",
      "datasourceTemplate": "github-tags"
    }
  ]
}
