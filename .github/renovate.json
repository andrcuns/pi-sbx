{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "enabledManagers": [
    "custom.regex",
    "dockerfile",
    "github-actions"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^\\.github/workflows/build\\.yml$"
      ],
      "matchStrings": [
        "MISE_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "jdx/mise",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^\\.github/workflows/build\\.yml$"
      ],
      "matchStrings": [
        "PI_VERSION=(?<currentValue>[\\d\\.]+)"
      ],
      "depNameTemplate": "@earendil-works/pi-coding-agent",
      "datasourceTemplate": "npm"
    }
  ]
}
